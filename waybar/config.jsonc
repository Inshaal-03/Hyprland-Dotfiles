{
  "include": [
    "~/Dotfiles/waybar/ModulesWorkspaces.txt"
  ],
  "reload_style_on_change": true,
  "height": 24,
  "margin-top": 0,
  "margin-right": 0,
  "margin-left": 0,
  "margin-bottom": 0,
  "layer": "top",
  "position": "top",
  "modules-left": [
    "custom/left#1",
    "hyprland/workspaces#kanji",
    "custom/right#1",
    "hyprland/window",
    "custom/seperator",
    "custom/media"
  ],
  "modules-center": [
    "group/mobo_drawer"
  ],
  "modules-right": [
    "custom/weather",
    // "custom/sysmon",
    "custom/seperator",
    "tray",
    "custom/seperator",
    "pulseaudio",
    "upower",
    "custom/seperator",
    "battery",
    "custom/seperator",
    "custom/notification",
    "custom/seperator",
    "clock"
  ],
  "custom/right#1": {
    "format": "î‚°"
  },
  "custom/left#1": {
    "format": "î‚²"
  },
  "custom/distro": {
    "format": "َ°£‡",
    "on-click": "rofi -show drun",
    "tooltip-format": "Open Rofi"
  },
  "hyprland/window": {
    "max-length": 25,
    "rewrite": {
      "": "<span foreground='#458588'></span>Desktop"
      // "kitty": "î¯ٹ Terminal",
      // "(.*):~": "î¯ٹ  Terminal",
      // "tmux(.*)": "<span foreground='#a6e3a1'>î¯ˆ</span> Tmux",
      // "(.*) â€” Zen Browser": "<span foreground='#d65d0e'>َ°؛• </span> $1",
      // "(.*)Zen Browser": "<span foreground='#d65d0e'>َ°؛• </span> Zen Browser",
      // "(.*) â€” Zen Twilight": "<span foreground='#537CF7'>َ°؛• </span> $1",
      // "(.*)Zen Twilight": "<span foreground='#537CF7'>َ°؛• </span> Zen Twilight",
      // "nvim": "<span foreground='#98971a'>îڑ® </span> Neovim",
      // "v": "<span foreground='#98971a'>îڑ® </span> Neovim",
      // "nvim (.*)": "<span foreground='#98971a'>îڑ® </span> $1",
      // "v (.*)": "<span foreground='#98971a'>îڑ® </span> $1",
      // "Gabut Download Manager": "ï€™ Gabut Download Manager",
      // "ONLYOFFICE Desktop Editors": "<span foreground='#cc241d'>î؛¨ </span> OnlyOffice Desktop"
    }
  },
  "battery": {
    "align": 0,
    "rotate": 0,
    "full-at": 100,
    "design-capacity": false,
    "states": {
      "good": 100,
      "warning": 30,
      "critical": 15
    },
    "format": "{capacity}% {icon}",
    "format-charging": "{capacity}% {icon}",
    "format-plugged": "{capacity}% َ±ک–",
    "format-alt-click": "click",
    "format-full": "{capacity}% {icon}",
    "format-alt": "{time} {icon}",
    "format-icons": {
      "charging": [
        "َ°¢œ",
        "َ°‚†",
        "َ°‚‡",
        "َ°‚ˆ",
        "َ°¢‌",
        "َ°‚‰",
        "َ°¢‍",
        "َ°‚ٹ",
        "َ°‚‹",
        "َ°‚…"
      ],
      "default": [
        "َ°پ؛",
        "َ°پ»",
        "َ°پ¼",
        "َ°پ½",
        "َ°پ¾",
        "َ°پ؟",
        "َ°‚€",
        "َ°‚پ",
        "َ°‚‚",
        "َ°پ¹"
      ]
    },
    "format-time": "{H}h {M}min",
    "tooltip": true,
    "tooltip-format": "{timeTo}"
  },
  "clock": {
    "format": "{:%d - %H:%M} îھ° ",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "year",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "format": {
        "months": "<span color='#ffead3'><b>{}</b></span>",
        "days": "<span color='#ecc6d9'><b>{}</b></span>",
        "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
        "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
        "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
      }
    },
    "actions": {
      "on-click-right": "mode"
    }
  },
  "tray": {
    "icon-size": 20,
    "spacing": 10
  },
  "network": {
    "format-wifi": "{essid} ({signalStrength}%) ï‡«",
    "format-ethernet": "{ipaddr}/{cidr} ï‍–",
    "format-linked": "{ifname} (No IP) َ°©ں",
    "format-disconnected": "Disconnected âڑ ",
    "on-click-right": "kitty nmtui",
    "tooltip": false
  },
  "pulseaudio": {
    "format": "{volume}%{format_source} {icon}",
    "format-bluetooth": "{volume}% {icon}",
    "format-bluetooth-muted": "{icon} ï‘¦",
    "format-muted": "ï‘¦ ",
    "format-source": "",
    "format-source-muted": "ï„±",
    "format-icons": {
      "headphone": "ï€¥",
      "hands-free": "ï–گ",
      "headset": "î¹™",
      "phone": "ï‚•",
      "portable": "ï‚•",
      "car": "ï†¹",
      "default": [
        "ï€¦ ",
        "ï€§ ",
        "ï€¨ "
      ]
    },
    "max-volume": 200,
    // "on-scroll-up": "wpctl set-volume @DEFAULT_SINK@ 10%+",
    // "on-scroll-down": "wpctl set-volume @DEFAULT_SINK@ 10%-",
    "on-click": "pavucontrol"
  },
  "group/mobo_drawer": {
    "orientation": "inherit",
    "modules": [
      "cpu",
      "temperature",
      "custom/distro",
      "memory",
      "disk"
    ]
  },
  "cpu": {
    "format": "{usage:>2}% َ°چ›",
    "interval": 1,
    "min-length": 5,
    "format-alt-click": "click",
    "format-alt": "{max_frequency} GHz َ°¾†"
  },
  "disk": {
    "interval": 30,
    "path": "/",
    "format": "{percentage_used}% َ°‹ٹ",
    "tooltip-format": "Click: Open Gnome Disks\nRight Click: Open Gnome Disk Usage Analyzer",
    "on-click": "gnome-disks",
    "on-click-right": "baobab /home/inshaal/"
  },
  "memory": {
    "interval": 10,
    "format": "{used:0.1f}GB î؟… ",
    "format-alt": "{percentage}% î؟… ",
    "format-alt-click": "click",
    "tooltip": false
  },
  "temperature": {
    "thermal-zone": 6,
    "interval": 10,
    "critical-threshold": 80,
    "format-critical": "{temperatureC}آ°C ï‹‡",
    "tooltip": false,
    "format": "{temperatureC}آ°C ï‹‰"
  },
  "group/network_drawer": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 500,
      "children-class": "cpu",
      "transition-left-to-right": true
    },
    "modules": [
      "tray",
      "network"
    ]
  },
  "custom/notification": {
    "tooltip": true,
    "tooltip-format": "Left Click: Launch Notification Center\nRight Click: Do not Disturb",
    "format": "{} {icon}",
    "format-icons": {
      "notification": "ï‚¢<span foreground='red'><sup>ï‘„</sup></span>",
      "none": "ï‚¢",
      "dnd-notification": "ï‡·<span foreground='red'><sup>ï‘„</sup></span>",
      "dnd-none": "ï‡·",
      "inhibited-notification": "ï‚¢<span foreground='red'><sup>ï‘„</sup></span>",
      "inhibited-none": "ï‚¢",
      "dnd-inhibited-notification": "ï‡·<span foreground='red'><sup>ï‘„</sup></span>",
      "dnd-inhibited-none": "ï‡·"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
  "upower": {
    "native-path": "/org/freedesktop/UPower/devices/headset_dev_DB_3E_52_DB_29_BC",
    "icon-size": 20,
    "hide-if-empty": true
  },
  "custom/weather": {
    "exec": "~/Dotfiles/waybar/weather.sh Karachi+Pakistan",
    "return-type": "json",
    "format": "{text}",
    "tooltip": true,
    "interval": 36000
  },
  "custom/media": {
    "format": "{icon}{text}",
    "return-type": "json",
    "format-icons": {
      "Playing": "ïپ‹ ",
      "Paused": "ïپŒ "
    },
    "max-length": 30,
    "exec": "playerctl -a metadata --format '{\"text\": \"{{markup_escape(title)}}\", \"tooltip\": \"{{playerName}} : {{markup_escape(title)}}\", \"alt\": \"{{status}}\", \"class\": \"{{status}}\"}' -F",
    "on-click": "playerctl play-pause"
  },
  "custom/seperator": {
    "format": "|"
  },
  "custom/sysmon": {
    "exec": "~/Dotfiles/waybar/monitor.py",
    "return-type": "json",
    "interval": 2,
    "tooltip": true
  }
}
